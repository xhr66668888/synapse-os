# Synapse OS Backend 环境变量示例

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/synapse_os
REDIS_URL=redis://localhost:6379/0

# JWT 认证
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Agent 配置 - AutoGLM (主力模型)
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_MODEL=autoglm-phone
WHISPER_MODEL=base

# AI Agent 配置 - MobileAgent (增强模型)
MOBILE_AGENT_API_KEY=your-modelscope-api-key
MOBILE_AGENT_BASE_URL=https://api-inference.modelscope.cn/v1
MOBILE_AGENT_MODEL=mPLUG/GUI-Owl-7B

# 双模型服务配置
DEFAULT_AGENT=autoglm
ROUTING_STRATEGY=cost_optimized
ENABLE_FALLBACK=true
ENABLE_REFLECTION=true
ENABLE_NOTETAKER=false
MAX_EXECUTION_STEPS=25
COST_LIMIT_PER_REQUEST=0.1

# AI Agent 配置 - UI-TARS (旗舰模型)
UI_TARS_API_KEY=hf_your-huggingface-api-key
UI_TARS_BASE_URL=https://your-endpoint.endpoints.huggingface.cloud/v1
UI_TARS_MODEL=tgi
UI_TARS_IMAGE_WIDTH=1920
UI_TARS_IMAGE_HEIGHT=1080

# 其他
DEBUG=true
